<header class="fixed top-0 left-0 right-0 z-50 bg-navy/95 backdrop-blur-sm border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">

            <!-- Logo -->
            <a href="/" class="flex flex-row md:flex-col items-baseline md:items-start group">
                <span
                    class="font-display font-bold text-xl text-white tracking-wide group-hover:text-gold transition-colors duration-200">
                    perito<span class="text-gold">forense</span>
                </span>
                <span
                    class="inline-block md:hidden text-white/50 text-base ml-0.5 group-hover:text-gold/70 transition-colors">.com.br</span>
                <span class="hidden md:block text-xs text-white/50 tracking-widest uppercase">.com.br</span>
            </a>

            <!-- Nav Desktop -->
            <nav class="hidden md:flex items-center gap-8">
                <!-- Dropdown: Cidades por Estado -->
                <div class="relative group/nav">
                    <button
                        class="flex items-center gap-1 text-sm text-white/70 hover:text-gold transition-colors duration-200 tracking-wide">
                        Cidades Atendidas
                        <svg class="w-3 h-3 transition-transform duration-200 group-hover/nav:rotate-180" fill="none"
                            stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    <!-- Dropdown panel -->
                    <div
                        class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-64 bg-navy border border-white/10 shadow-xl opacity-0 invisible group-hover/nav:opacity-100 group-hover/nav:visible transition-all duration-200 z-50">
                        <div class="p-2">
                            <div class="grid grid-cols-3 gap-1">
                                <% publishedStates.forEach(function(state) { %>
                                    <a href="/<%= state.uf.toLowerCase() %>"
                                        class="px-2 py-1.5 text-center text-xs font-display text-white/50 hover:text-gold hover:bg-white/5 transition-colors duration-150">
                                        <%= state.uf %>
                                    </a>
                                    <% }); %>
                            </div>
                            <div class="border-t border-white/10 mt-2 pt-2 px-1 text-center">
                                <a href="/cidades"
                                    class="block text-xs font-display text-gold/60 hover:text-gold transition-colors py-1">
                                    Ver mapa completo →
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <a href="/#especialidades"
                    class="text-sm text-white/70 hover:text-gold transition-colors duration-200 tracking-wide">Especialidades</a>
                <a href="/#profissionais"
                    class="text-sm text-white/70 hover:text-gold transition-colors duration-200 tracking-wide">Para
                    Peritos</a>
                <a href="https://wa.me/<%= WHATSAPP_NUMBER %>?text=Olá,%20gostaria%20de%20falar%20sobre%20perícia%20forense."
                    target="_blank" rel="noopener"
                    class="px-5 py-2.5 border border-gold text-gold text-sm font-display tracking-widest hover:bg-gold hover:text-navy transition-all duration-200">
                    Contato
                </a>
            </nav>

            <!-- Mobile actions -->
            <div class="flex items-center gap-3 md:hidden">
                <a href="https://wa.me/<%= WHATSAPP_NUMBER %>?text=Olá,%20gostaria%20de%20falar%20sobre%20perícia%20forense."
                    target="_blank" rel="noopener"
                    class="px-4 py-2 bg-gold/10 border border-gold/50 text-gold text-sm font-display tracking-widest hover:bg-gold hover:text-navy transition-all duration-200">
                    WhatsApp
                </a>
                <button id="mobile-menu-btn" class="p-2 -mr-2 text-white/70 hover:text-gold transition-colors"
                    aria-label="Abrir menu">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
            </div>

        </div>
    </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu"
    class="fixed inset-0 z-40 bg-navy/98 backdrop-blur-md hidden flex-col pt-24 pb-safe transition-opacity duration-300 opacity-0">
    <div class="flex flex-col items-center justify-center flex-1 gap-8 p-4">
        <a href="/" class="text-2xl font-display font-medium text-white tracking-wide hover:text-gold transition-colors"
            onclick="closeMobileMenu()">Início</a>
        <a href="/cidades"
            class="text-2xl font-display font-medium text-white tracking-wide hover:text-gold transition-colors"
            onclick="closeMobileMenu()">Cidades Atendidas</a>
        <a href="/#especialidades"
            class="text-2xl font-display font-medium text-white tracking-wide hover:text-gold transition-colors"
            onclick="closeMobileMenu()">Especialidades</a>
        <a href="/#profissionais"
            class="text-2xl font-display font-medium text-white tracking-wide hover:text-gold transition-colors"
            onclick="closeMobileMenu()">Para Peritos</a>

        <div class="mt-8 border-t border-white/10 w-3/4 pt-8 flex justify-center">
            <a href="https://wa.me/<%= WHATSAPP_NUMBER %>?text=Olá,%20preciso%20de%20assistência%20técnica%20judicial."
                target="_blank" rel="noopener"
                class="px-8 py-4 bg-gold text-navy font-display font-bold text-sm tracking-widest uppercase hover:bg-gold/90 transition-colors"
                onclick="closeMobileMenu()">
                Falar com a Central
            </a>
        </div>
    </div>
</div>

<script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    let isMenuOpen = false;

    // SVG Icons
    const iconMenu = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
    const iconClose = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />';

    btn.addEventListener('click', () => {
        if (isMenuOpen) {
            closeMobileMenu();
        } else {
            isMenuOpen = true;
            menu.classList.remove('hidden');
            // Small delay to allow reflow so the transition works
            requestAnimationFrame(() => {
                menu.classList.remove('opacity-0');
                menu.classList.add('flex', 'opacity-100');
            });
            btn.querySelector('svg').innerHTML = iconClose;
            document.body.style.overflow = 'hidden';
        }
    });

    function closeMobileMenu() {
        isMenuOpen = false;
        menu.classList.remove('opacity-100');
        menu.classList.add('opacity-0');
        btn.querySelector('svg').innerHTML = iconMenu;
        document.body.style.overflow = '';

        // Wait for fade out to hide
        setTimeout(() => {
            menu.classList.add('hidden');
            menu.classList.remove('flex');
        }, 300);
    }
</script>