<!-- City Hub — /:uf/:city -->

<!-- Hero da cidade -->
<section class="pb-14 bg-navy relative overflow-hidden" style="padding-top: 110px;">
    <div class="absolute inset-0 opacity-5"
        style="background-image: linear-gradient(rgba(201,168,76,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(201,168,76,0.3) 1px, transparent 1px); background-size: 60px 60px;">
    </div>
    <div
        class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold to-transparent opacity-40">
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-xs font-display tracking-widest uppercase mb-6"
            aria-label="Breadcrumb">
            <a href="/" class="text-white/30 hover:text-gold transition-colors">Portal</a>
            <span class="text-white/20">›</span>
            <span class="text-white/40">
                <%= city.uf %>
            </span>
            <span class="text-white/20">›</span>
            <span class="text-gold">
                <%= city.name %>
            </span>
        </nav>

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1 border border-gold/30 bg-gold/5 mb-5">
            <span class="w-1.5 h-1.5 rounded-full bg-gold"></span>
            <span class="text-gold text-xs font-display tracking-widest uppercase">Hub Regional</span>
        </div>

        <h1 class="font-display font-bold text-4xl md:text-5xl text-white leading-tight mb-4">
            Peritos Forenses em <span class="text-gold">
                <%= city.name %>
            </span>
        </h1>
        <p class="font-serif text-white/50 text-lg max-w-2xl">
            Selecione a área de perícia que você precisa. Cada posição é ocupada por
            apenas um profissional nesta região.
        </p>
    </div>
</section>

<!-- Grade de especialidades -->
<section class="py-14 bg-steel">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <% specialties.forEach(function(s) { %>
                <% if (!s.is_hidden) { %>
                    <a href="/<%= city.uf.toLowerCase() %>/<%= city.slug %>/<%= s.slug %>"
                        class="group relative bg-navy border border-white border-opacity-10 hover:border-gold hover:border-opacity-30 transition-all duration-300 overflow-hidden">

                        <!-- Barra lateral de status -->
                        <div
                            style="position:absolute;left:0;top:0;bottom:0;width:3px;background:<%= s.is_active ? '#34d399' : 'rgba(201,168,76,0.3)' %>">
                        </div>

                        <div class="p-5" style="padding-left:1.25rem">
                            <!-- Nome + número -->
                            <div class="flex items-start justify-between gap-4 mb-2">
                                <h2
                                    class="font-display font-bold text-white text-sm leading-snug group-hover:text-gold transition-colors duration-200">
                                    <%= s.name %>
                                </h2>
                                <span class="flex-shrink-0 font-display font-bold text-xs mt-0.5"
                                    style="color:rgba(255,255,255,0.12)">
                                    <%= String(s.sort_order).padStart(2,'0') %>
                                </span>
                            </div>

                            <!-- Descrição -->
                            <p class="font-serif text-xs leading-relaxed mb-4" style="color:rgba(255,255,255,0.35)">
                                <%= s.description %>
                            </p>

                            <!-- Status badge + seta -->
                            <div class="flex items-center justify-between">
                                <% if (s.is_active) { %>
                                    <span class="flex items-center gap-1.5 text-xs font-display" style="color:#34d399">
                                        <span class="w-1.5 h-1.5 rounded-full inline-block"
                                            style="background:#34d399"></span>
                                        Perito disponível
                                    </span>
                                    <% } else { %>
                                        <span class="flex items-center gap-1.5 text-xs font-display"
                                            style="color:rgba(201,168,76,0.55)">
                                            <span class="w-1.5 h-1.5 rounded-full border inline-block"
                                                style="border-color:rgba(201,168,76,0.4)"></span>
                                            Vaga em seleção
                                        </span>
                                        <% } %>
                                            <span class="text-xs group-hover:text-gold transition-colors duration-200"
                                                style="color:rgba(255,255,255,0.2)">→</span>
                            </div>
                        </div>
                    </a>
                    <% } %>
                        <% }); %>
        </div>

        <!-- Rodapé do hub -->
        <div class="mt-10 pt-8 text-center" style="border-top:1px solid rgba(255,255,255,0.08)">
            <p class="font-serif text-sm mb-5" style="color:rgba(255,255,255,0.3)">
                Não encontrou a especialidade que precisa, ou precisa de urgência?
            </p>
            <a href="https://wa.me/<%= WHATSAPP_NUMBER %>?text=Olá,%20preciso%20de%20um%20perito%20forense%20em%20<%= encodeURIComponent(city.name) %>."
                target="_blank" rel="noopener"
                class="inline-flex items-center gap-2 px-6 py-3 font-display text-xs tracking-widest uppercase transition-all duration-200"
                style="border:1px solid rgba(201,168,76,0.4);color:#c9a84c"
                onmouseover="this.style.background='#c9a84c';this.style.color='#0a1628'"
                onmouseout="this.style.background='';this.style.color='#c9a84c'">
                Falar com a Central
            </a>
        </div>

    </div>
</section>