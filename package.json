{
  "name": "peritoforense.com.br",
  "version": "1.0.0",
  "description": "Portal Nacional de Perícia Forense e Assistência Técnica Judicial",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/styles.css --watch",
    "dev:full": "npm run build:css && npm run dev",
    "setup-db": "node scripts/setup-database.js",
    "seed": "node scripts/seed.js"
  },
  "author": "Corpo Digital",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.6.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.9",
    "nodemon": "^3.1.9",
    "tailwindcss": "^4.0.9"
  }
}
