<header class="fixed top-0 left-0 right-0 z-50 bg-navy/95 backdrop-blur-sm border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">

            <!-- Logo -->
            <a href="/" class="flex flex-col leading-tight group">
                <span
                    class="font-display font-bold text-lg md:text-xl text-white tracking-wide group-hover:text-gold transition-colors duration-200">
                    perito<span class="text-gold">forense</span>
                </span>
                <span class="text-xs text-white/50 tracking-widest uppercase">.com.br</span>
            </a>

            <!-- Nav Desktop -->
            <nav class="hidden md:flex items-center gap-8">
                <!-- Dropdown: Cidades por Estado -->
                <div class="relative group/nav">
                    <button
                        class="flex items-center gap-1 text-sm text-white/70 hover:text-gold transition-colors duration-200 tracking-wide">
                        Cidades
                        <svg class="w-3 h-3 transition-transform duration-200 group-hover/nav:rotate-180" fill="none"
                            stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    <!-- Dropdown panel -->
                    <div
                        class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-64 bg-navy border border-white/10 shadow-xl opacity-0 invisible group-hover/nav:opacity-100 group-hover/nav:visible transition-all duration-200 z-50">
                        <div class="p-2">
                            <div class="grid grid-cols-3 gap-1">
                                <% publishedStates.forEach(function(state) { %>
                                    <a href="/<%= state.uf.toLowerCase() %>"
                                        class="px-2 py-1.5 text-center text-xs font-display text-white/50 hover:text-gold hover:bg-white/5 transition-colors duration-150">
                                        <%= state.uf %>
                                    </a>
                                    <% }); %>
                            </div>
                            <div class="border-t border-white/10 mt-2 pt-2 px-1">
                                <a href="/#especialidades"
                                    class="block text-xs font-display text-gold/60 hover:text-gold transition-colors py-1">
                                    Ver todas as especialidades →
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <a href="/#especialidades"
                    class="text-sm text-white/70 hover:text-gold transition-colors duration-200 tracking-wide">Especialidades</a>
                <a href="/#profissionais"
                    class="text-sm text-white/70 hover:text-gold transition-colors duration-200 tracking-wide">Para
                    Peritos</a>
                <a href="https://wa.me/<%= WHATSAPP_NUMBER %>" target="_blank" rel="noopener"
                    class="px-5 py-2 border border-gold text-gold text-sm font-display tracking-widest hover:bg-gold hover:text-navy transition-all duration-200">
                    Contato
                </a>
            </nav>

            <!-- Mobile: só o botão de WhatsApp -->
            <a href="https://wa.me/<%= WHATSAPP_NUMBER %>" target="_blank" rel="noopener"
                class="md:hidden px-4 py-2 border border-gold text-gold text-xs font-display tracking-widest hover:bg-gold hover:text-navy transition-all duration-200">
                Contato
            </a>

        </div>
    </div>
</header>